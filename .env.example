GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=openai/llama-3.1-8b-instant
# Speech-to-text (Whisper via Groq). Audio is sent from the backend to Groq.
GROQ_STT_MODEL=whisper-large-v3-turbo
# Optional override (defaults to Groq OpenAI-compatible endpoint)
# GROQ_API_BASE=https://api.groq.com/openai/v1
